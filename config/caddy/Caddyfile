:8000 {
	@borealis path /borealis /borealis/*
	handle @borealis {
		uri strip_prefix /borealis
		reverse_proxy 127.0.0.1:8015
	}

	@gemma4 path /gemma4 /gemma4/*
	handle @gemma4 {
		uri strip_prefix /gemma4
		reverse_proxy 127.0.0.1:8016
	}

	@nvidia_qwen path /nvidia_qwen /nvidia_qwen/*
	handle @nvidia_qwen {
		uri strip_prefix /nvidia_qwen
		reverse_proxy 127.0.0.1:8017
	}

	handle {
		respond "unknown model route" 404
	}
}
