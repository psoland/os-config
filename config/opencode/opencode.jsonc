  "permission": {
    "skill": {
      "*": "allow",
      "better-auth-*": "allow",
      "experimental-*": "ask",
      // "web-design-guidlines": "deny"
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": false
    },
    "shadcn": {
      "type": "local",
      "command": ["npx", "shadcn@latest", "mcp"],
      "enabled": false
    }
  }
}
