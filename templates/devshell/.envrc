# See https://direnv.net/

# Use the flake's default devShell
use flake

# Or use a specific shell:
# use flake .#node
# use flake .#python
# use flake .#go

# Additional environment setup can go here:
# export MY_VAR="value"

# Load local overrides if they exist
# source_env_if_exists .envrc.local
